# ── 네이버 검색 API (https://developers.naver.com/apps) ──
# "검색" API를 추가한 애플리케이션의 Client ID / Secret
NAVER_CLIENT_ID=여기에_네이버_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_네이버_클라이언트_SECRET

# ── Google Gemini API (https://aistudio.google.com/apikey) ──
GEMINI_API_KEY=여기에_Gemini_API_키
# 사용할 Gemini 모델 (기본값 gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# 서버 포트 (기본값 3000)
PORT=3000
